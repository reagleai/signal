# Backend webhook base URL (used by serverless API proxy routes)
N8N_BASE_URL=https://your-n8n-instance.example.com/webhook

# Feedback webhook URL (used by the feedback proxy route)
N8N_FEEDBACK_WEBHOOK=https://your-n8n-instance.example.com/webhook/feedback-received

# Frontend webhook URLs (used by the browser for direct-to-backend calls)
# These are VITE_ prefixed so they are available in the client bundle.
# If not set, the frontend will fall back to the internal /api/* proxy routes.
VITE_N8N_WEBHOOK_RUN_URL=https://your-n8n-instance.example.com/webhook/signal/run
VITE_N8N_WEBHOOK_CHAT_URL=https://your-n8n-instance.example.com/webhook/signal/chat
